<?xml version="1.0" encoding="UTF-8"?>
<Container version="2">
  <Name>nginx</Name>
  <Repository>nginx:latest</Repository>
  <Registry>https://hub.docker.com/r/library/nginx/</Registry>
  <Network>bridge</Network>
  <MyIP></MyIP>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support>https://nginx.org/</Support>
  <Project>https://nginx.org/</Project>
  <Overview>Nginx is a web server.</Overview>
  <Category>Network:Web</Category>
  <WebUI>http://[IP]:[PORT:80]/</WebUI>
  <TemplateURL></TemplateURL>
  <Icon>https://raw.githubusercontent.com/nginx/nginx/master/docs/icon.png</Icon>
  <ExtraParams></ExtraParams>
  <PostArgs></PostArgs>
  <CPUset></CPUset>
  <DateInstalled>1699900000</DateInstalled>
  <DonateText></DonateText>
  <DonateLink></DonateLink>
  <Requires></Requires>
  <Config Name="WebUI Port" Target="80" Default="8080" Mode="tcp" Description="Port for web interface" Type="Port" Display="always" Required="true" Mask="false">8080</Config>
  <Config Name="Config Path" Target="/etc/nginx" Default="/mnt/user/appdata/nginx" Mode="rw" Description="Nginx config directory" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/nginx</Config>
</Container>
